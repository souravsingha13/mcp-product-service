{
	"extends": "./tsconfig.json",
	"compilerOptions": {
		"outDir": "./dist/out-tsc",
		"types": [],
		"module": "commonjs",
		"target": "es2019",
		"moduleResolution": "node",
		"allowJs": false,
		"noImplicitAny": true,
		"strict": true,
		"esModuleInterop": true,
		"skipLibCheck": true
	},
	"include": [
		"src/**/*.ts"
	],
	"exclude": [
		"src/**/*.spec.ts",
		"node_modules",
		"dist"
	]
}
